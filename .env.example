# Copy this file to `.env` and supply real secrets. DO NOT commit `.env`.

# Admin credentials (single-admin demo only). Use a proper user store in production.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_to_a_strong_password

# Session secret used for HMAC signing of session tokens
SESSION_SECRET=replace_with_a_long_random_value

# SMTP settings for sending emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM="Payroll Team <no-reply@yourcompany.com>"

# NODE_ENV=development|production
NODE_ENV=development
# ─── Database ──────────────────────────────────────────────────────────────────
# Prisma Postgres or standard PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host:5432/salary_slip_db"

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Single admin credentials. Use a strong, unique password.
ADMIN_EMAIL="admin@yourcompany.com"
ADMIN_PASSWORD="change-me-to-a-strong-password"

# Secret key for HMAC session signing. Generate with: openssl rand -hex 32
SESSION_SECRET="generate-a-random-secret-here"

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_COMPANY_NAME="Acme Corp"
COMPANY_ADDRESS="123 Business Park, Mumbai, India"

# ─── Email (SMTP) ──────────────────────────────────────────────────────────────
# Mailtrap sandbox SMTP credentials for local testing.
# Copy these values from your Mailtrap inbox's SMTP settings.
SMTP_HOST="sandbox.smtp.mailtrap.io"
SMTP_PORT="2525"
SMTP_USER="your-mailtrap-username"
SMTP_PASS="your-mailtrap-password"
# Optional: override the default sender display name + address.
SMTP_FROM="Payroll Team <no-reply@yourcompany.com>"

# ─── Supabase (optional — for Storage or Auth extensions) ─────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
